# ─── Stripe ──────────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
# Flip to live keys (sk_live_…) when you launch — see README checklist.
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook` (dev)
# or Dashboard → Developers → Webhooks (prod)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Automation handoff ─────────────────────────────────────────────
# Your n8n endpoint. On payment, the full briefing is POSTed here as JSON:
# { event, product, orderId, amountTotal, currency, briefing{…}, bump, utm{…} }
AUTOMATION_WEBHOOK_URL=https://your-n8n-instance.com/webhook/tuneofus

# ─── Kie.ai (Suno) — direct generation ──────────────────────────────
# If AUTOMATION_WEBHOOK_URL is empty and this is set, the site generates
# the song itself after payment (POST api.kie.ai/api/v1/generate) and
# logs finished track URLs at /api/kie/callback. Also powers
# /api/generate-song for testing.
KIE_API_KEY=your_kie_key
# Suno model: V3_5 | V4 | V4_5 | V4_5PLUS | V4_5ALL | V5 | V5_5
KIE_SUNO_MODEL=V5

# ─── Site config ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tuneofus.com
# Social-proof counter in the hero eyebrow
NEXT_PUBLIC_TEARS_COUNT=12,000+
# "Launch price — ends soon" pill. Flag only — never a fake countdown.
NEXT_PUBLIC_SHOW_URGENCY=true
